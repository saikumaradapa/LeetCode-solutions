class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        return len(s) == len(goal) and goal in s + s

'''
    if s can be rotated to goal, then goal is a substring of s + s
    e.g. s = "abcde", s + s = "abcdeabcde", goal = "cdeab" is found in it
    time complexity : O(n)
    space complexity : O(n)
'''

##############################################################################################################################

class Solution:
    def rotateString(self, s: str, goal: str) -> bool:
        if s == goal:
            return True 

        n = len(s)
        s_arr = [ch for ch in s]
        goal_arr = [ch for ch in goal]

        for i in range(n):
            s_arr.append(s_arr.pop(0))

            if s_arr == goal_arr:
                return True
        return False 

''' time complexity : O(n ^ 2)
    space complexity : O(n)
'''




